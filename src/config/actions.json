{
    "version": "2.0",
    "schedule": {
        "blink": {
            "min_interval_ms": 2000,
            "max_interval_ms": 5000
        },
        "walk": {
            "min_interval_ms": 12000,
            "max_interval_ms": 35000,
            "first_delay_min_ms": 5000,
            "first_delay_max_ms": 12000
        },
        "sleep": {
            "idle_duration_ms": 300000
        }
    },
    "animations": {
        "idle": {
            "anim_name": "idle",
            "fps": 8,
            "loop": true,
            "ping_pong": false,
            "duration_ms": -1
        },
        "blink": {
            "anim_name": "idle",
            "overlay_blink": true,
            "fps": 15,
            "loop": false,
            "duration_ms": 950
        },
        "walk": {
            "anim_name": "walk",
            "fps": 8,
            "loop": true,
            "speed_px_per_sec": 50,
            "duration_ms": -1
        },
        "eat": {
            "anim_name": "eat",
            "fps": 8,
            "loop": true,
            "duration_ms": 5500
        },
        "sleep": {
            "anim_name": "sleep",
            "fps": 4,
            "loop": true,
            "ping_pong": true,
            "duration_ms": -1
        },
        "sad": {
            "anim_name": "sad",
            "fps": 8,
            "loop": true,
            "duration_ms": -1
        },
        "happy": {
            "anim_name": "happy",
            "fps": 8,
            "loop": false,
            "duration_ms": 4000
        },
        "click": {
            "anim_name": "click",
            "fps": 5,
            "loop": false,
            "duration_ms": 1100
        },
        "grabbed": {
            "anim_name": "hover",
            "fps": 10,
            "loop": true,
            "duration_ms": -1
        },
        "fall": {
            "anim_name": "click",
            "fps": 10,
            "loop": false,
            "duration_ms": 900
        }
    },
    "transitions": {
        "idle": {
            "allowed_to": ["blink", "walk", "eat", "sleep", "sad", "happy", "click", "grabbed", "fall"]
        },
        "blink": {
            "allowed_to": ["idle"]
        },
        "walk": {
            "allowed_to": ["idle"]
        },
        "eat": {
            "allowed_to": ["idle", "grabbed"]
        },
        "sleep": {
            "allowed_to": ["idle", "click", "grabbed"]
        },
        "sad": {
            "allowed_to": ["idle", "happy", "click", "grabbed", "eat", "walk"]
        },
        "happy": {
            "allowed_to": ["idle", "click", "grabbed"]
        },
        "click": {
            "allowed_to": ["idle", "grabbed"]
        },
        "grabbed": {
            "allowed_to": ["idle", "fall", "click"]
        },
        "fall": {
            "allowed_to": ["idle"]
        }
    }
}
